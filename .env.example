# --- Telegram API ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_USER_IDS=12345678,98765432

# --- Binance API (Real) ---
API_KEY_BINANCE=your_api_key_here
SECRET_API_KEY_BINANCE=your_secret_key_here

# --- Binance API (Testnet) ---
TEST_API_KEY_BINANCE=your_testnet_api_key_here
TEST_SECRET_API_KEY_BINANCE=your_testnet_secret_key_here

# --- Database & Redis ---
DATABASE_URL=postgresql+asyncpg://quant_user:quant_password@postgres:5432/quant_db
REDIS_URL=redis://redis:6379

# PostgreSQL Internal (Docker)
POSTGRES_USER=quant_user
POSTGRES_PASSWORD=quant_password
POSTGRES_DB=quant_db

# --- Trading Mode ---
TESTNET=True
IS_TRADING_ENABLED=True

# --- Security ---
ENCRYPTION_KEY=your_encryption_key_here
