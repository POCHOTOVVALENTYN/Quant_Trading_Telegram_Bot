# --- Telegram API ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_USER_IDS=12345678,98765432

# --- Binance API (Real) ---
API_KEY_BINANCE=your_api_key_here
SECRET_API_KEY_BINANCE=your_secret_key_here

# --- Binance API (Testnet) ---
TEST_API_KEY_BINANCE=your_testnet_api_key_here
TEST_SECRET_API_KEY_BINANCE=your_testnet_secret_key_here

# --- Database & Redis ---
DATABASE_URL=postgresql+asyncpg://quant_user:quant_password@postgres:5432/quant_db
REDIS_URL=redis://redis:6379

# PostgreSQL Internal (Docker)
POSTGRES_USER=quant_user
POSTGRES_PASSWORD=quant_password
POSTGRES_DB=quant_db

# --- Trading Mode ---
TESTNET=True
IS_TRADING_ENABLED=True
# Optional: regime router (ADX trend vs range); defaults match config/settings.py
# STRATEGY_REGIME_ROUTING_ENABLED=True
# REGIME_ADX_TREND_MIN=22
# REGIME_ADX_RANGE_MAX=18

# --- Security ---
ENCRYPTION_KEY=your_encryption_key_here

# ====================================================================
# EXTERNAL AI PROVIDERS — cascade fallback
# ====================================================================
# Order of providers to try (first = primary, rest = fallback)
AI_CASCADE_ORDER=groq,grok,gemini,openrouter

# Groq (free: 30 RPM, Llama 3.3 70B)
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile

# xAI / Grok ($25/mo free credit)
GROK_API_KEY=your_grok_key
GROK_API_URL=https://api.x.ai
GROK_MODEL=grok-3-mini

# Google Gemini (free: 15 RPM)
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter (free models available)
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
